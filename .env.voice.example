# Voice agent + LiveKit — merge into repo root .env (loaded by voice CLI + API)

LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_TOKEN=

# Armenian STT (Whisper-compatible HTTP). Example self-host: faster-whisper + small FastAPI wrapper.
VOICE_STT_ENDPOINT=
VOICE_STT_API_KEY=

# Armenian TTS HTTP (JSON in, WAV base64 or raw bytes out).
VOICE_TTS_ENDPOINT=
VOICE_TTS_API_KEY=

# Groq (same as root .env) for grounded answers
GROQ_API_KEY=

# Optional: VOICE_USE_MOCK=1
