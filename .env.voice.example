# Voice agent + LiveKit — merge into repo root .env (loaded by voice CLI + API)

# Self-hosted LiveKit only (not LiveKit Cloud). http/https are normalized to ws/wss.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Optional: pre-minted JWT for the agent identity. If empty, the voice agent mints a token using API_KEY+SECRET (same as /api/livekit/token).
LIVEKIT_TOKEN=
LIVEKIT_ROOM=banking-support-room

VOICE_STT_ENDPOINT=
VOICE_STT_API_KEY=
# Optional read timeout override (seconds) for slow local Whisper
# VOICE_STT_TIMEOUT_SECONDS=180
VOICE_TTS_ENDPOINT=
VOICE_TTS_API_KEY=
# VOICE_TTS_TIMEOUT_SECONDS=120

GEMINI_API_KEY=

# Optional: VOICE_USE_MOCK=1 (STT+TTS mock; no real speech)
