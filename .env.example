# Root .env — used when you run Python from repo root (python-dotenv in run_runtime_api + voice CLI).
# Split templates: .env.backend.example, .env.voice.example, .env.frontend.example
#
# Production LLM (minimal): set GEMINI_API_KEY below after `pip install -r requirements.txt`.
# Voice demo also needs VOICE_STT_ENDPOINT / VOICE_TTS_ENDPOINT (or VOICE_USE_MOCK=1).

# --- Backend / ingestion ---
EMBEDDING_MODEL_NAME=Metric-AI/armenian-text-embeddings-2-large
# auto | cpu | cuda | mps
# EMBEDDING_DEVICE=auto
# EMBEDDING_BATCH_SIZE=32
# GPU FAISS search (needs faiss GPU build): FAISS_USE_GPU=1  FAISS_GPU_ID=0
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_RETRIES=3
SCRAPER_USER_AGENT=voice-ai-banking-support-agent/0.1

# --- Google Gemini (required for Armenian LLM synthesis when runtime_config has answer.backend: llm) ---
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: GOOGLE_API_KEY=   (alias, if you already use Google AI Studio env naming)
# LLM_PROVIDER=gemini       (default)
# LLM_MODEL=gemini-2.0-flash
# LLM_MODEL=gemini-1.5-pro  (often stronger Armenian, slower / different quota)
# LLM_MAX_TOKENS=8192
# LLM_API_KEY=              (generic fallback if set without GEMINI_API_KEY)

# Local Whisper STT read timeout (seconds); default in code is 180 if not set in voice_config.yaml
# VOICE_STT_TIMEOUT_SECONDS=240

# --- LiveKit (self-hosted; Docker: docker compose up -d) ---
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM=banking-support-room
LIVEKIT_TOKEN=

# --- Armenian voice (HTTP) ---
VOICE_STT_ENDPOINT=
VOICE_STT_API_KEY=
VOICE_TTS_ENDPOINT=
VOICE_TTS_API_KEY=

# Force mock STT/TTS (CI / no speech servers): VOICE_USE_MOCK=1
# Tests / no Gemini: LLM_PROVIDER=mock
