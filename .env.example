# Root .env — used when you run Python from repo root (python-dotenv in run_runtime_api + voice CLI).
# Split templates: .env.backend.example, .env.voice.example, .env.frontend.example

# --- Backend / ingestion ---
EMBEDDING_MODEL_NAME=Metric-AI/armenian-text-embeddings-2-large
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_RETRIES=3
SCRAPER_USER_AGENT=voice-ai-banking-support-agent/0.1

# --- Groq LLM (required for fluent Armenian answers; runtime_config uses answer.backend: llm) ---
# https://console.groq.com — create API key
GROQ_API_KEY=
# Optional overrides (defaults in llm_config.yaml):
# LLM_MODEL=llama-3.1-8b-instant
# LLM_ENDPOINT=https://api.groq.com/openai/v1/chat/completions

# --- LiveKit (self-hosted; Docker: docker compose up -d) ---
# Must be ws:// or wss:// (not http://). After changing docker/livekit.yaml: docker compose up -d --force-recreate
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM=banking-support-room
# Agent JWT: python scripts/generate_livekit_token.py --identity banking-support-agent
LIVEKIT_TOKEN=

# --- Armenian voice (HTTP) — production path ---
# Local sample servers (after: pip install -e ".[voice_local_servers]"):
#   python scripts/voice_http_stt_server.py   → http://127.0.0.1:8088/transcribe
#   python scripts/voice_http_tts_server.py   → http://127.0.0.1:8089/synthesize  (miniaudio; no ffmpeg)
VOICE_STT_ENDPOINT=
VOICE_STT_API_KEY=
VOICE_TTS_ENDPOINT=
VOICE_TTS_API_KEY=

# Force mock STT/TTS (CI / no speech servers): VOICE_USE_MOCK=1
