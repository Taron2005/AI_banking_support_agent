# Root .env — used when you run Python from repo root (python-dotenv in run_runtime_api + voice CLI).
# Split templates: .env.backend.example, .env.voice.example, .env.frontend.example
#
# Production LLM (minimal): set GEMINI_API_KEY below after `pip install -r requirements.txt`.
# Voice demo also needs VOICE_STT_ENDPOINT / VOICE_TTS_ENDPOINT (or VOICE_USE_MOCK=1).

# --- Backend / ingestion ---
EMBEDDING_MODEL_NAME=Metric-AI/armenian-text-embeddings-2-large
# auto | cpu | cuda | mps
# EMBEDDING_DEVICE=auto
# EMBEDDING_BATCH_SIZE=32
# GPU FAISS search (needs faiss GPU build): FAISS_USE_GPU=1  FAISS_GPU_ID=0
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_RETRIES=3
SCRAPER_USER_AGENT=voice-ai-banking-support-agent/0.1

# --- Google Gemini (required for Armenian LLM synthesis when runtime_config has answer.backend: llm) ---
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: GOOGLE_API_KEY=   (alias, if you already use Google AI Studio env naming)
# LLM_PROVIDER=gemini       (default)
# LLM_MODEL=gemini-2.0-flash
# LLM_MODEL=gemini-1.5-pro  (often stronger Armenian, slower / different quota)
# LLM_MAX_TOKENS=8192
# LLM_API_KEY=              (generic fallback if set without GEMINI_API_KEY)

# Local Whisper STT read timeout (seconds); default in code is 180 if not set in voice_config.yaml
# VOICE_STT_TIMEOUT_SECONDS=240
# Default Whisper size (start_stack.ps1 and voice_http_stt_server.py): base | small | medium | large-v3 (default small if unset)
# VOICE_WHISPER_MODEL=small
# Local STT decode: beam 1 = fastest (default). Wider beam if transcripts are often empty: VOICE_WHISPER_BEAM=3
# VOICE_WHISPER_BEAM=1
# VOICE_WHISPER_BEAM_RETRY=3
# LiveKit agent: wait for mic track subscription after PTT start (seconds)
# VOICE_MIC_TRACK_WAIT_SECONDS=0.85
# Pause after PTT end before draining PCM buffer (seconds)
# VOICE_PCM_TRAIL_PAUSE_SECONDS=0.22
# Published assistant audio track sample rate (must match playout normalization; default 24000)
# VOICE_LIVEKIT_PUBLISH_SAMPLE_RATE=24000
# Real-time pacing between LiveKit frames: 1|0 (default off in voice_config; set 1 if you hear underruns)
# VOICE_LIVEKIT_PLAYOUT_PACING=0
# If TTS returns raw pcm_s16le, sample rate of those bytes (Edge/local default 24000)
# VOICE_TTS_PCM_SAMPLE_RATE=24000

# --- LiveKit (self-hosted; Docker: docker compose up -d) ---
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM=banking-support-room
LIVEKIT_TOKEN=

# --- Armenian voice (HTTP) ---
VOICE_STT_ENDPOINT=
VOICE_STT_API_KEY=
VOICE_TTS_ENDPOINT=
VOICE_TTS_API_KEY=

# Voice agent uses the same POST /chat session as the web UI (default). Start API on :8000 first.
# VOICE_RUNTIME_API_URL=http://127.0.0.1:8000
# In-process voice (duplicate embedder load; enables stream_llm_tokens without /chat): VOICE_RUNTIME_HTTP=0

# Local scripts/voice_http_tts_server.py: Armenian hy-AM Edge voices are missing for some regions;
# the server falls back automatically. Override order with:
# EDGE_TTS_FALLBACK_VOICES=en-US-AndrewMultilingualNeural,en-US-GuyNeural
# Edge TTS speech rate (script default +10%; use +0% for normal speed)
# VOICE_EDGE_TTS_RATE=+0%
# Voice agent POST /chat top_k — align with Vite UI (default 8)
# VOICE_CHAT_TOP_K=8

# Force mock STT/TTS (CI / no speech servers): VOICE_USE_MOCK=1
# Tests / no Gemini: LLM_PROVIDER=mock
