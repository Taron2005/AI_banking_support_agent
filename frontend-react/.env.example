# Vite — only VITE_* is exposed to the browser
# Leave unset during `npm run dev` to use Vite proxy → http://127.0.0.1:8000 (see vite.config.js)
# VITE_API_BASE_URL=http://127.0.0.1:8000
# Optional overrides (defaults come from GET /api/livekit/config and /ready)
# VITE_LIVEKIT_URL=ws://127.0.0.1:7880
# VITE_LIVEKIT_IDENTITY=web-user-1
